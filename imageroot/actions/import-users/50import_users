import json
import sys
import subprocess
import samba

request = json.load(sys.stdin)  # object with skip_existing + records list
sambatool_cmd = ['podman', 'exec', '-i', 'samba-dc', 'samba-tool']

skip_existing = request.get('skip_existing', False)
records = request.get('records', [])

# Fetch existing users and groups with LDAP queries (single ldbsearch for each type)
existing_users = set()
existing_groups = set()
ldbsearch_users_cmd = ['podman', 'exec', '-i', 'samba-dc', 'ldbsearch', '-H', '/var/lib/samba/private/sam.ldb', 'objectClass=user', 'sAMAccountName']
proc_u = subprocess.run(ldbsearch_users_cmd, capture_output=True, text=True, check=True)
for line in proc_u.stdout.splitlines():
    if line.startswith('sAMAccountName:'):
        existing_users.add(line.split(':',1)[1].strip())
ldbsearch_groups_cmd = ['podman', 'exec', '-i', 'samba-dc', 'ldbsearch', '-H', '/var/lib/samba/private/sam.ldb', 'objectClass=group', 'sAMAccountName']
proc_g = subprocess.run(ldbsearch_groups_cmd, capture_output=True, text=True, check=True)
for line in proc_g.stdout.splitlines():
    if line.startswith('sAMAccountName:'):
        existing_groups.add(line.split(':',1)[1].strip())

# 1. Create users (only missing ones, or all if they don't exist). If skip_existing True, skip creation.
for rec in records:
    user = rec['user']
    if user in existing_users and skip_existing:
        continue  # leave existing untouched
    if user in existing_users and not skip_existing:
        # user exists and must be updated, not created
        continue

    password = rec.get('password', '')
    must_change = rec.get('must_change_password') is True

    adduser_cmd = sambatool_cmd + ['user', 'create', user]
    if must_change:
        adduser_cmd += ['--must-change-at-next-login']

    if not password:
        adduser_cmd += ['--random-password']
        inputdata = None
    else:
        inputdata = password + "\n" + password + "\n"

    subprocess.run(adduser_cmd, input=inputdata, stdout=sys.stderr, check=True, text=True)

# 2. Handle password reset for existing users when skip_existing == False and password provided
for rec in records:
    user = rec['user']
    if user in existing_users and not skip_existing and 'password' in rec:
        password = rec['password']
        must_change = rec.get('must_change_password') is True
        inputdata = password + "\n" + password + "\n"
        setpwd_cmd = sambatool_cmd + ['user', 'setpassword', user]
        if must_change:
            setpwd_cmd += ['--must-change-at-next-login']
        subprocess.run(setpwd_cmd, input=inputdata, stdout=sys.stderr, check=True, text=True)

# 3. Ensure requested groups exist and collect memberships (do not remove existing membership)
# Create missing groups first
for rec in records:
    for g in rec.get('groups', []) or []:
        if g not in existing_groups:
            # create group
            create_group_cmd = sambatool_cmd + ['group', 'add', g]
            subprocess.run(create_group_cmd, stdout=sys.stderr, check=True, text=True)
            existing_groups.add(g)

add_groups_map = {}
for rec in records:
    if skip_existing and rec['user'] in existing_users:
        continue  # do not touch groups of existing users
    for g in rec.get('groups', []) or []:
        add_groups_map.setdefault(g, []).append(rec['user'])

for group, members in add_groups_map.items():
    cmd = sambatool_cmd + ['group', 'addmembers', group] + members
    subprocess.run(cmd, stdout=sys.stderr, check=True, text=True)

# 4. Collect DN and prepare single ldbmodify for mail/displayName/userAccountControl changes
ldb_entries = []
for rec in records:
    user = rec['user']
    # Skip attribute updates on existing if skip_existing True
    if skip_existing and user in existing_users:
        continue

    mail = rec.get('mail')  # could be None
    display_name = rec.get('display_name')
    no_pwd_exp = rec.get('no_password_expiration')

    # If no attributes to update, skip querying
    if mail is None and display_name is None and no_pwd_exp is None:
        continue

    getdn_cmd = sambatool_cmd + ['user', 'show', user, '--attributes=dn,userAccountControl']
    proc = subprocess.run(getdn_cmd, check=True, capture_output=True, text=True)
    dn_line = None
    uac_line = None
    for line in proc.stdout.strip().splitlines():
        if line.startswith('dn:'):
            dn_line = line
        elif line.startswith('userAccountControl:'):
            uac_line = line
    if not dn_line:
        continue

    modifications = []
    if mail is not None:
        if mail != '':
            modifications.append('replace: mail\nmail: ' + mail)
        else:
            modifications.append('delete: mail')
    if display_name is not None:
        if display_name != '':
            modifications.append('replace: displayName\ndisplayName: ' + display_name)
        else:
            modifications.append('delete: displayName')
    if no_pwd_exp is not None and uac_line:
        current_uac = int(uac_line.split(':', 1)[1].strip())
        UF_DONT_EXPIRE_PASSWORD = 0x10000
        new_uac = current_uac
        if no_pwd_exp is True and not (current_uac & UF_DONT_EXPIRE_PASSWORD):
            new_uac |= UF_DONT_EXPIRE_PASSWORD
        elif no_pwd_exp is False and (current_uac & UF_DONT_EXPIRE_PASSWORD):
            new_uac &= ~UF_DONT_EXPIRE_PASSWORD
        if new_uac != current_uac:
            modifications.append('replace: userAccountControl\nuserAccountControl: ' + str(new_uac))

    if modifications:
        entry = dn_line + '\nchangetype: modify\n' + '\n'.join(modifications) + '\n'
        ldb_entries.append(entry)

if ldb_entries:
    ldbmodify_cmd = ['podman', 'exec', '-i', 'samba-dc', 'ldbmodify', '-H', '/var/lib/samba/private/sam.ldb']
    ldb_input = '\n'.join(ldb_entries)
    subprocess.run(ldbmodify_cmd, input=ldb_input, stdout=sys.stderr, check=True, text=True)

# 5. Lock users if requested (creation or update). Skip existing when skip_existing True
for rec in records:
    if rec.get('locked') is True and not (skip_existing and rec['user'] in existing_users):
        lock_cmd = sambatool_cmd + ['user', 'disable', rec['user']]
        subprocess.run(lock_cmd, stdout=sys.stderr, check=True, text=True)
